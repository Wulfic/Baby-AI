# Baby-AI Environment Configuration
# Copy this file to .env and fill in your values.
# DO NOT commit the .env file to version control.

# ── Minecraft ──────────────────────────────────────────────────
# Path to your .minecraft directory
MC_DIR=C:\Users\YOUR_USER\AppData\Roaming\.minecraft
MC_VERSION=1.21.11
# Precreate your world and put its name here
MC_WORLD_NAME=training
MC_PLAYER_NAME=YOUR_PLAYER_NAME
# Get from https://mcuuid.net/ or
# by running `data get entity @s UUID` in Minecraft direectly
MC_PLAYER_UUID=YOUR_PLAYER_UUID
# JVM heap for Minecraft in MB (4096 = 4 GB min recommended; 2048 causes GC thrashing on 1.21+)
MC_MAX_MEMORY_MB=4096

# ── Storage ────────────────────────────────────────────────────
# Path for checkpoints, replay data, logs, etc.
BABY_AI_STORAGE=Z:\Baby_AI
